# Database (Railway provides this automatically when you add PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/database

# Server
NODE_ENV=production
PORT=3001

# Security
JWT_SECRET=your-secure-jwt-secret-here

# AI (for The Gaffer chat feature)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Frontend URL (for CORS - set to your Vercel domain)
FRONTEND_URL=https://touchline.xyz

# Email (optional - for invites and notifications)
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=Touchline <noreply@send.touchline.xyz>

# Stripe (for payments)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
