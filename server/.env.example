# Database (Railway provides this automatically when you add PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/database

# Server
NODE_ENV=production
PORT=3001

# Security
JWT_SECRET=your-secure-jwt-secret-here

# AI (for the coaching assistant)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Frontend URL (for CORS)
FRONTEND_URL=https://schools.touchline.xyz

# Email (for invites and notifications)
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=Touchline for Schools <noreply@send.schools.touchline.xyz>

# Video (Mux)
MUX_TOKEN_ID=your-mux-token-id
MUX_TOKEN_SECRET=your-mux-token-secret

# Storage (S3)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=your-s3-bucket-name
AWS_REGION=eu-west-2

# Voice Observations (transcription)
TRANSCRIPTION_PROVIDER=assemblyai
ASSEMBLYAI_API_KEY=your-assemblyai-api-key
