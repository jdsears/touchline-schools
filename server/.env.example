# Database (Railway provides this automatically when you add PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/database

# Server
NODE_ENV=production
PORT=3001

# Security
JWT_SECRET=your-secure-jwt-secret-here

# AI (for the coaching assistant)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Frontend URL (for CORS)
FRONTEND_URL=https://app.moonbootssports.com

# Canonical host (for domain redirect)
CANONICAL_HOST=app.moonbootssports.com

# App identity
VITE_APP_NAME=MoonBoots Sports

# Email (for invites and notifications via Resend)
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=MoonBoots Sports <noreply@moonbootssports.com>
EMAIL_FROM_DOMAIN=moonbootssports.com
EMAIL_FROM_NAME=MoonBoots Sports

# Video (Mux)
MUX_TOKEN_ID=your-mux-token-id
MUX_TOKEN_SECRET=your-mux-token-secret

# Storage (Cloudflare R2 — S3-compatible, no egress fees)
# Create a bucket and API token at dash.cloudflare.com → R2
S3_BUCKET=moonboots-sports
S3_ACCESS_KEY_ID=your-r2-access-key
S3_SECRET_ACCESS_KEY=your-r2-secret-key
S3_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
S3_REGION=auto
S3_PUBLIC_URL=https://pub-xxx.r2.dev

# Voice Observations (transcription)
TRANSCRIPTION_PROVIDER=assemblyai
ASSEMBLYAI_API_KEY=your-assemblyai-api-key

# SSO – Microsoft 365 (Azure AD)
# Register an app at portal.azure.com → Azure Active Directory → App registrations
# Add redirect URI: https://app.moonbootssports.com/api/sso/microsoft/callback
# Required API permissions: openid, profile, email (Microsoft Graph delegated)
MICROSOFT_CLIENT_ID=your-azure-app-client-id
MICROSOFT_CLIENT_SECRET=your-azure-app-client-secret
MICROSOFT_TENANT_ID=common
# BACKEND_URL=https://app.moonbootssports.com  # Only needed if server != frontend domain

# SSO – Google Workspace for Education
# Create OAuth2 credentials at console.cloud.google.com → APIs & Services → Credentials
# Add redirect URI: https://app.moonbootssports.com/api/sso/google/callback
# Required scopes: openid, profile, email
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Stripe (enterprise billing)
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Calendly (demo booking)
CALENDLY_URL=https://calendly.com/moonboots-sports/demo

# Prospect Demo Instance (v1.4)
# Set to true on the production instance to enable nightly Ashworth Park Academy reset at 03:00 UK
DEMO_RESET_ENABLED=false
